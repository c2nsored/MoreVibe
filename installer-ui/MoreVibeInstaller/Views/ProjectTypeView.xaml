<UserControl x:Class="MoreVibeInstaller.Views.ProjectTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock FontSize="22" FontWeight="SemiBold" Text="프로젝트 유형 선택" />
        <TextBlock Margin="0,10,0,0"
                   TextWrapping="Wrap"
                   Text="프로젝트 유형을 고르면 그에 맞는 기본 역할 구성과 전문 support skill이 함께 설치됩니다." />

        <StackPanel Margin="0,20,0,0">
            <RadioButton GroupName="ProjectType"
                         FontSize="15"
                         IsChecked="{Binding ProjectTypeWebApp}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="웹앱(일반)" />
                    <TextBlock Foreground="#475569" Text="프론트엔드와 백엔드가 함께 있는 일반적인 웹 서비스 프로젝트" />
                </StackPanel>
            </RadioButton>

            <RadioButton GroupName="ProjectType"
                         Margin="0,14,0,0"
                         FontSize="15"
                         IsChecked="{Binding ProjectTypeEcommerce}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="이커머스 / 쇼핑몰" />
                    <TextBlock Foreground="#475569" Text="상품, 장바구니, 주문/결제가 있는 상점형 프로젝트" />
                </StackPanel>
            </RadioButton>

            <RadioButton GroupName="ProjectType"
                         Margin="0,14,0,0"
                         FontSize="15"
                         IsChecked="{Binding ProjectTypeBlog}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="블로그 / 콘텐츠 사이트" />
                    <TextBlock Foreground="#475569" Text="글과 콘텐츠 발행이 중심인 사이트 또는 문서형 프로젝트" />
                </StackPanel>
            </RadioButton>

            <RadioButton GroupName="ProjectType"
                         Margin="0,14,0,0"
                         FontSize="15"
                         IsChecked="{Binding ProjectTypeApi}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="API 서버" />
                    <TextBlock Foreground="#475569" Text="라우트, 데이터 계층, 백엔드 계약이 중심인 서비스" />
                </StackPanel>
            </RadioButton>

            <RadioButton GroupName="ProjectType"
                         Margin="0,14,0,0"
                         FontSize="15"
                         IsChecked="{Binding ProjectTypeGeneric}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="기타(자동 감지)" />
                    <TextBlock Foreground="#475569" Text="정해진 유형이 아니면 프로젝트 구조를 바탕으로 범용 역할을 배치합니다." />
                </StackPanel>
            </RadioButton>
        </StackPanel>

        <Border Margin="0,20,0,0" Padding="14" Background="#F6F8FA" CornerRadius="12">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="현재 선택" />
                <TextBlock Margin="0,8,0,0" Text="{Binding ProjectTypeSummary}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
