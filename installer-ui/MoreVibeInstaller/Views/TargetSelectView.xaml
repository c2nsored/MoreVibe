<UserControl x:Class="MoreVibeInstaller.Views.TargetSelectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock FontSize="22" FontWeight="SemiBold" Text="설치 대상 선택" />
        <TextBlock Margin="0,10,0,0"
                   TextWrapping="Wrap"
                   Text="MoreVibe를 연결할 AI 환경을 선택하세요. 하나만 선택해도 되고 여러 개를 함께 선택해도 됩니다." />
        <StackPanel Margin="0,20,0,0">
            <CheckBox Content="Codex" FontSize="15" IsChecked="{Binding InstallCodex}" />
            <CheckBox Margin="0,10,0,0" Content="Claude Code" FontSize="15" IsChecked="{Binding InstallClaudeCode}" />
            <CheckBox Margin="0,10,0,0" Content="Antigravity" FontSize="15" IsChecked="{Binding InstallAntigravity}" />
        </StackPanel>
        <Border Margin="0,20,0,0" Padding="14" Background="#F6F8FA" CornerRadius="12">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="현재 선택" />
                <TextBlock Margin="0,8,0,0" Text="{Binding TargetSummary}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
