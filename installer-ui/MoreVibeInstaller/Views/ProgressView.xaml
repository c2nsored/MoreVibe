<UserControl x:Class="MoreVibeInstaller.Views.ProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock FontSize="22" FontWeight="SemiBold" Text="설치 진행 중" />
        <TextBlock Margin="0,10,0,0" Text="{Binding StatusText}" />
        <ProgressBar Margin="0,18,0,0" Height="16" IsIndeterminate="True" />
        <TextBox Margin="0,18,0,0"
                 Height="300"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 Text="{Binding LogsText}" />
    </StackPanel>
</UserControl>
