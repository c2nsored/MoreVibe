<UserControl x:Class="MoreVibeInstaller.Views.ProjectSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock FontSize="22" FontWeight="SemiBold" Text="프로젝트 설정" />
        <TextBlock Margin="0,10,0,0"
                   TextWrapping="Wrap"
                   Text="원하는 경우 프로젝트 루트를 지정해서 .morevibe 구조와 프로젝트 규칙 파일 연결까지 함께 설치할 수 있습니다." />
        <CheckBox Margin="0,20,0,0"
                  Content="프로젝트에는 설치하지 않고 전역 설정만 적용"
                  IsChecked="{Binding SkipProjectBootstrap}" />
        <TextBlock Margin="0,20,0,6" FontWeight="SemiBold" Text="프로젝트 루트 경로" />
        <DockPanel>
            <TextBox MinWidth="420" Text="{Binding ProjectPath, UpdateSourceTrigger=PropertyChanged}" />
            <Button Margin="10,0,0,0" Command="{Binding BrowseProjectPathCommand}" Content="찾아보기" DockPanel.Dock="Right" />
        </DockPanel>
        <CheckBox Margin="0,16,0,0"
                  Content="기존 .morevibe가 있으면 백업 후 교체"
                  IsChecked="{Binding ForceProjectTemplate}" />
        <Border Margin="0,20,0,0" Padding="14" Background="#F6F8FA" CornerRadius="12">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="현재 설정" />
                <TextBlock Margin="0,8,0,0" Text="{Binding ProjectSummary}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
