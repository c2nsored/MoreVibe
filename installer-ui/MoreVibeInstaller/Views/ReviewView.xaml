<UserControl x:Class="MoreVibeInstaller.Views.ReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock FontSize="22" FontWeight="SemiBold" Text="설치 내용 확인" />
        <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Text="아래 내용을 확인한 뒤 설치를 시작하세요." />

        <Border Margin="0,20,0,0" Padding="16" Background="#F6F8FA" CornerRadius="12">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="설치 대상" />
                <TextBlock Margin="0,8,0,0" Text="{Binding TargetSummary}" />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="프로젝트 적용" />
                <TextBlock Margin="0,8,0,0" Text="{Binding ProjectSummary}" />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="역할 기본 구성" />
                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding ProjectTypeSummary}" />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="첫 세션 예문" />
                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding FirstSessionExample}" />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="선택형 고급 기능" />
                <TextBlock Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Text="MoreVibe 명령어는 있으면 빠르게 쓸 수 있지만 필수는 아닙니다. 설치 후에는 자연어로 세션을 시작해도 충분합니다." />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="안전한 적용" />
                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="기존 파일은 가능한 한 병합하고, 필요한 경우 백업한 뒤 적용합니다." />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
